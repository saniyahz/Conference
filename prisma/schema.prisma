// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NextAuth Account model for OAuth providers (Google, etc.)
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// NextAuth Session model
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// NextAuth VerificationToken model
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String?   // Optional for OAuth users
  emailVerified DateTime?
  image         String?
  role          String    @default("user") // "user" | "superuser"
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  subscription  Subscription?
  stories       Story[]
  orders        PrintOrder[]
  usageTracking UsageTracking?
}

model Subscription {
  id                   String   @id @default(cuid())
  userId               String   @unique
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // "free", "plus", "unlimited", "library_starter", "library_plus", "library_max"
  plan                 String   @default("free")
  audience             String   @default("parent") // "parent" | "school"
  billingCycle         String?  // "monthly", "yearly"
  status               String   @default("active") // "active", "cancelled", "expired", "past_due"

  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?  @unique
  stripePriceId        String?

  currentPeriodStart   DateTime @default(now())
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean  @default(false)

  // School plan: link to the school org (null for parent plans)
  schoolId             String?
  school               School?  @relation(fields: [schoolId], references: [id])

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

// ── School organisation ───────────────────────────
model School {
  id                   String   @id @default(cuid())
  name                 String
  adminUserId          String   // the user who manages billing

  // Current plan limits (denormalised for fast checks)
  maxStudents          Int      @default(250)
  sharedBookPool       Int      @default(500)
  booksUsedThisMonth   Int      @default(0)

  // Add-ons (stored as JSON string: [{id, quantity}])
  activeAddOns         String   @default("[]")

  // Multi-school bundle
  parentBundleId       String?  // links to a SchoolBundle if part of a multi-school deal

  subscriptions        Subscription[]
  students             SchoolStudent[]

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([adminUserId])
}

model SchoolStudent {
  id                   String   @id @default(cuid())
  schoolId             String
  school               School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  userId               String?  // linked user account (nullable for invite-pending)
  studentName          String?
  grade                String?  // e.g. "3rd", "K"
  className            String?  // e.g. "Ms. Rivera's Class"

  booksCreatedThisMonth Int     @default(0)

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([schoolId])
  @@index([userId])
}

model SchoolBundle {
  id                   String   @id @default(cuid())
  name                 String?  // e.g. "Springfield District"
  adminUserId          String
  discountPercent      Int      @default(15) // 15% per additional school
  schoolIds            String   // JSON array of school IDs in bundle

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([adminUserId])
}

model UsageTracking {
  id                    String   @id @default(cuid())
  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Monthly usage counters (reset each billing period)
  storiesCreatedThisMonth  Int      @default(0)
  downloadsThisMonth       Int      @default(0)
  audioPlaysThisMonth      Int      @default(0)

  // Lifetime totals
  totalStoriesCreated      Int      @default(0)
  totalDownloads           Int      @default(0)
  totalAudioPlays          Int      @default(0)

  // Last reset date for monthly counters
  lastResetDate            DateTime @default(now())

  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model Story {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  title           String
  author          String?
  originalPrompt  String?  // What the kid originally said
  pages           String   // JSON string of pages
  coverImage      String?
  language        String   @default("en")  // ISO 639-1 language code

  isSaved         Boolean  @default(false)
  downloadCount   Int      @default(0)
  audioPlayCount  Int      @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
}

model PrintOrder {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  storyId         String
  storyTitle      String?

  status          String   // "pending", "processing", "printed", "shipped", "delivered", "cancelled"

  // Pricing
  basePrice       Float
  discountPercent Float    @default(0)
  discountAmount  Float    @default(0)
  shippingCost    Float    @default(0)
  totalPrice      Float

  // Shipping details
  shippingName    String?
  shippingAddress String?
  shippingCity    String?
  shippingState   String?
  shippingZip     String?
  shippingCountry String?
  trackingNumber  String?

  // Stripe payment
  stripePaymentIntentId String?

  // Gelato print-on-demand integration
  gelatoOrderId   String?   // Gelato's order ID (e.g., "ord_xxx")
  gelatoStatus    String?   // Raw Gelato status string for debugging
  pdfUrl          String?   // Public URL of the uploaded print-ready PDF

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
}
