# Replicate API Token (Get at https://replicate.com/account/api-tokens)
REPLICATE_API_TOKEN=your_replicate_token_here

# OpenAI API Key for TTS voices (Get at https://platform.openai.com/api-keys)
OPENAI_API_KEY=your_openai_api_key_here

# Database URL (SQLite for development)
DATABASE_URL="file:./dev.db"

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_here_generate_with_openssl_rand_base64_32

# Stripe Configuration (Get keys at https://stripe.com/docs/keys)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ── Parent Plan Stripe Price IDs ──────────────────
STRIPE_PLUS_MONTHLY_PRICE_ID=price_xxx
STRIPE_PLUS_YEARLY_PRICE_ID=price_xxx
STRIPE_UNLIMITED_MONTHLY_PRICE_ID=price_xxx
STRIPE_UNLIMITED_YEARLY_PRICE_ID=price_xxx

# ── School Plan Stripe Price IDs ──────────────────
STRIPE_SCHOOL_STARTER_MONTHLY_PRICE_ID=price_xxx
STRIPE_SCHOOL_STARTER_YEARLY_PRICE_ID=price_xxx
STRIPE_SCHOOL_PLUS_MONTHLY_PRICE_ID=price_xxx
STRIPE_SCHOOL_PLUS_YEARLY_PRICE_ID=price_xxx
STRIPE_SCHOOL_MAX_MONTHLY_PRICE_ID=price_xxx
STRIPE_SCHOOL_MAX_YEARLY_PRICE_ID=price_xxx

# App URL for redirects
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Print Provider (gelato or lulu) ────────────────
PRINT_PROVIDER=gelato

# ── Gelato Print-on-Demand ──────────────────────────
GELATO_API_KEY=your_gelato_api_key
GELATO_WEBHOOK_SECRET=your_gelato_webhook_secret

# ── Lulu Print-on-Demand ───────────────────────────
# Get credentials at https://developers.lulu.com/ (production)
# or https://developers.sandbox.lulu.com/ (sandbox)
LULU_CLIENT_KEY=your_lulu_client_key
LULU_CLIENT_SECRET=your_lulu_client_secret
LULU_SANDBOX=true
LULU_WEBHOOK_SECRET=your_lulu_webhook_secret

# ── Cloudflare R2 (PDF storage for print orders) ────
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=storybook-pdfs
R2_PUBLIC_URL=https://your-bucket.r2.dev
